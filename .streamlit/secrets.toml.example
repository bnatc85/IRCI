# Streamlit Secrets Configuration
# Copy this file and rename to secrets.toml for local development
# For Streamlit Cloud: Add these secrets in the app settings dashboard

# Financial Modeling Prep API Key
# Get your key at: https://financialmodelingprep.com/
FMP_API_KEY = "your_fmp_api_key_here"

# OpenAI API Key (for AI Assistant feature)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY = "your_openai_api_key_here"

# Alpha Vantage API Key (optional)
# Get your key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY = "your_alpha_vantage_key_here"

# Access Code (change this to your custom code)
ACCESS_CODE = "Melissa2019"
